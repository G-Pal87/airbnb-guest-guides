---
const navLinks = [
  { href: '#getting-here', label: 'Getting Here', i18nKey: 'ui.gettingHere' },
  { href: '#checkin', label: 'Check-in', i18nKey: 'ui.checkIn' },
  { href: '#house-rules', label: 'House Rules', i18nKey: 'ui.houseRules' },
  { href: '#wifi', label: 'WiFi & Appliances', i18nKey: 'ui.appliances' },
  { href: '#things-to-do', label: 'Things To Do', i18nKey: 'ui.thingsToDo' },
  { href: '#emergency', label: 'Emergencies', i18nKey: 'ui.emergency' },
  { href: '#checkout', label: 'Check-out', i18nKey: 'ui.checkout' },
  { href: '#contact', label: 'Contact', i18nKey: 'ui.contact' },
];
---

<nav
  id="main-nav"
  class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm border-b border-stone-100"
  aria-label="Property guide navigation"
>
  <div class="overflow-x-auto scrollbar-hide">
    <ul class="flex flex-row items-center gap-1 px-3 py-2 min-w-max md:min-w-0 md:justify-center md:flex-wrap">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link inline-block text-sm font-medium text-primary px-3 py-2 rounded-lg whitespace-nowrap transition-colors duration-150 hover:bg-primary hover:text-white active:bg-primary active:text-white focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-1 min-h-[44px] flex items-center"
            data-i18n={link.i18nKey}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
