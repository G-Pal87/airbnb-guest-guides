---
interface Props {
  property: {
    checkin: {
      keyLocation: string;
      accessCode: string;
      steps: string[];
      notes: string;
    };
  };
}

const { property } = Astro.props;
---

<section id="checkin" class="py-12 bg-surface" aria-labelledby="checkin-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="checkin-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
      Check-in
    </h2>

    <!-- Key location + access code -->
    <div class="bg-accent/10 border-2 border-accent/30 rounded-2xl p-5 mb-6">
      <div class="flex items-start gap-3 mb-4">
        <span class="text-2xl flex-shrink-0" aria-hidden="true">🔑</span>
        <div>
          <p class="text-sm font-semibold text-stone-500 uppercase tracking-wide mb-0.5">Key Location</p>
          <p class="font-semibold text-charcoal text-base">{property.checkin.keyLocation}</p>
        </div>
      </div>
      <div class="flex items-center gap-4 bg-white rounded-xl p-4">
        <span class="text-xl" aria-hidden="true">🔢</span>
        <div>
          <p class="text-xs font-semibold text-stone-500 uppercase tracking-wide mb-0.5">Access Code</p>
          <p class="font-mono font-bold text-3xl text-charcoal tracking-widest" aria-label={`Access code: ${property.checkin.accessCode}`}>
            {property.checkin.accessCode}
          </p>
        </div>
      </div>
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-2xl shadow-md p-5 mb-5 border border-stone-100">
      <h3 class="font-semibold text-charcoal mb-4 flex items-center gap-2">
        <span aria-hidden="true">📋</span> Step-by-Step
      </h3>
      <ol class="space-y-4">
        {property.checkin.steps.map((step: string, i: number) => (
          <li class="flex items-start gap-4">
            <span
              class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-white font-bold text-sm flex items-center justify-center"
              aria-hidden="true"
            >
              {i + 1}
            </span>
            <p class="text-stone-700 text-sm leading-relaxed pt-1">{step}</p>
          </li>
        ))}
      </ol>
    </div>

    <!-- Notes -->
    {property.checkin.notes && (
      <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4 flex items-start gap-3">
        <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">ℹ️</span>
        <p class="text-blue-800 text-sm leading-relaxed">{property.checkin.notes}</p>
      </div>
    )}
  </div>
</section>
