---
interface Props {
  property: {
    checkout: {
      time: string;
      steps: string[];
      lateCheckout: string;
    };
  };
}

const { property } = Astro.props;
---

<section id="checkout" class="py-12 bg-surface" aria-labelledby="checkout-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="checkout-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
      Check-out
    </h2>

    <!-- Checkout time -->
    <div class="bg-white rounded-2xl shadow-md p-5 mb-6 border border-stone-100 flex items-center gap-4">
      <span class="text-3xl flex-shrink-0" aria-hidden="true">🕙</span>
      <div>
        <p class="text-sm font-semibold text-stone-500 uppercase tracking-wide mb-0.5">Checkout Time</p>
        <p class="font-bold text-4xl text-primary" aria-label={`Checkout by ${property.checkout.time}`}>
          {property.checkout.time}
        </p>
      </div>
    </div>

    <!-- Steps -->
    <div class="bg-white rounded-2xl shadow-md p-5 mb-5 border border-stone-100">
      <h3 class="font-semibold text-charcoal mb-4 flex items-center gap-2">
        <span aria-hidden="true">✅</span> Checkout Checklist
      </h3>
      <ol class="space-y-4">
        {property.checkout.steps.map((step: string, i: number) => (
          <li class="flex items-start gap-4">
            <span
              class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-amber-700 font-bold text-sm flex items-center justify-center"
              aria-hidden="true"
            >
              {i + 1}
            </span>
            <p class="text-stone-700 text-sm leading-relaxed pt-1">{step}</p>
          </li>
        ))}
      </ol>
    </div>

    <!-- Late checkout note -->
    {property.checkout.lateCheckout && (
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 flex items-start gap-3">
        <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">💡</span>
        <p class="text-amber-800 text-sm leading-relaxed">{property.checkout.lateCheckout}</p>
      </div>
    )}
  </div>
</section>
