---
interface Props {
  property: {
    checkout: {
      time: string;
      steps: string[];
      lateCheckout: string;
    };
  };
}

const { property } = Astro.props;

function stepIcon(step: string): string {
  const s = step.toLowerCase();
  if (s.includes('fridge') || s.includes('food')) return '🧊';
  if (s.includes('dish') || s.includes('washing')) return '🍽️';
  if (s.includes('rubbish') || s.includes('bin') || s.includes('trash') || s.includes('waste')) return '🗑️';
  if (s.includes('window') || s.includes('balcony') || s.includes('door')) return '🪟';
  if (s.includes('air con') || s.includes('light') || s.includes('switch off') || s.includes('tv')) return '💡';
  if (s.includes('key') || s.includes('keybox') || s.includes('reception') || s.includes('card')) return '🔑';
  if (s.includes('whatsapp') || s.includes('message') || s.includes('let me know') || s.includes('let us know') || s.includes('contact')) return '💬';
  return '✅';
}

function stepTitle(step: string): string {
  const s = step.toLowerCase();
  if (s.includes('fridge') || s.includes('food')) return 'Clear the fridge';
  if (s.includes('dish') || s.includes('washing')) return 'Wash up the dishes';
  if (s.includes('rubbish') || s.includes('bin') || s.includes('trash') || s.includes('waste')) return 'Take out the rubbish';
  if (s.includes('window') || s.includes('balcony') || s.includes('close')) return 'Close windows & doors';
  if (s.includes('appliance')) return 'Switch off lights & appliances';
  if (s.includes('air con') || s.includes('light') || s.includes('switch off') || s.includes('tv')) return 'Switch off lights & AC';
  if (s.includes('key') || s.includes('keybox') || s.includes('reception')) return 'Return the keys';
  if (s.includes('whatsapp') || s.includes('message') || s.includes('let us know') || s.includes('let me know')) return s.includes('drop us') || s.includes('let us know') ? 'Drop us a message!' : 'Drop me a message!';
  return step.split(/[.!,]/)[0].slice(0, 45);
}
---

<section id="checkout" class="py-12 bg-surface" aria-labelledby="checkout-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="checkout-heading" class="font-serif text-3xl font-bold text-charcoal mb-8" data-i18n="ui.checkout">
      Check-out
    </h2>

    <!-- Checkout time -->
    <div class="bg-white rounded-2xl shadow-md p-5 mb-6 border border-stone-100 flex items-center gap-4">
      <span class="text-3xl flex-shrink-0" aria-hidden="true">🕙</span>
      <div>
        <p class="text-sm font-semibold text-stone-500 uppercase tracking-wide mb-0.5" data-i18n="ui.checkoutTime">Checkout Time</p>
        <p class="font-bold text-4xl text-primary" aria-label={`Checkout by ${property.checkout.time}`}>
          {property.checkout.time}
        </p>
      </div>
    </div>

    <!-- Checklist as accordion -->
    <h3 class="font-semibold text-charcoal mb-3 flex items-center gap-2" data-i18n="ui.checkoutChecklist">
      <span aria-hidden="true">✅</span> Checkout Checklist
    </h3>
    <div class="space-y-3 mb-5">
      {property.checkout.steps.map((step: string, i: number) => (
        <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">{stepIcon(step)}</span>
            <span class="font-semibold text-charcoal flex-1">{stepTitle(step)}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4">
              <p class="text-stone-600 text-sm leading-relaxed" data-i18n={`checkout.steps.${i}`}>{step}</p>
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Late checkout note -->
    {property.checkout.lateCheckout && (
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 flex items-start gap-3">
        <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">💡</span>
        <p class="text-amber-800 text-sm leading-relaxed" data-i18n="checkout.lateCheckout">{property.checkout.lateCheckout}</p>
      </div>
    )}
  </div>
</section>
