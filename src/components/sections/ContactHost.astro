---
interface ContactPerson {
  name: string;
  role?: string;
  phone: string;
  whatsapp: string;
  email?: string;
}

interface Props {
  property: {
    host: ContactPerson;
    cohost?: ContactPerson;
    hostPhoto?: string;
  };
}

const { property } = Astro.props;

function formatTelLink(number: string): string {
  return number.replace(/\s/g, '');
}

function formatWhatsAppLink(number: string): string {
  return number.replace(/[\s+]/g, '');
}

const hasCohost = !!property.cohost;
---

<section id="contact" class="py-12 bg-white" aria-labelledby="contact-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="contact-heading" class="font-serif text-3xl font-bold text-charcoal mb-3" data-i18n="ui.contactHost">
      Contact Your Host
    </h2>
    <p class="text-stone-500 text-base mb-6 leading-relaxed">
      We're here for you throughout your stay. Don't hesitate to reach out with any questions, requests, or if anything needs attention — we genuinely want you to have a wonderful time.
    </p>

    {property.hostPhoto && (
      <div class="mb-6 rounded-2xl overflow-hidden shadow-md border border-stone-100">
        <img
          src={property.hostPhoto}
          alt="Your hosts"
          class="w-full object-cover max-h-56"
        />
      </div>
    )}

    {hasCohost ? (
      <div class="grid grid-cols-2 gap-3 mb-6">
        {/* Host (Giorgos) — left */}
        <div class="bg-surface rounded-2xl shadow-md p-4 border border-stone-100 flex flex-col gap-3">
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <span class="text-lg">🏡</span>
            </div>
            <div class="min-w-0">
              <p class="font-bold text-charcoal text-sm leading-tight">{property.host.name}</p>
              <p class="text-stone-500 text-xs">Your Host</p>
            </div>
          </div>
          <a
            href={`tel:${formatTelLink(property.host.phone)}`}
            class="flex items-center gap-2 bg-primary text-white rounded-xl px-3 py-2.5 hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-1 min-h-[48px]"
            aria-label={`Call ${property.host.name}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div class="min-w-0">
              <p class="text-xs text-white/70 font-medium">Call</p>
              <p class="font-semibold text-xs truncate">{property.host.phone}</p>
            </div>
          </a>
          <a
            href={`https://wa.me/${formatWhatsAppLink(property.host.whatsapp)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-green-500 text-white rounded-xl px-3 py-2.5 hover:bg-green-600 transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-1 min-h-[48px]"
            aria-label={`WhatsApp ${property.host.name}`}
          >
            <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs text-white/70 font-medium">WhatsApp</p>
              <p class="font-semibold text-xs truncate">{property.host.whatsapp}</p>
            </div>
          </a>
          {property.host.email && (
            <a
              href={`mailto:${property.host.email}`}
              class="flex items-center gap-2 bg-stone-100 text-charcoal rounded-xl px-3 py-2.5 hover:bg-stone-200 transition-colors focus:outline-none focus:ring-2 focus:ring-stone-400 focus:ring-offset-1 min-h-[48px]"
              aria-label={`Email ${property.host.name}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div class="min-w-0">
                <p class="text-xs text-stone-500 font-medium">Email</p>
                <p class="font-semibold text-xs truncate">{property.host.email}</p>
              </div>
            </a>
          )}
        </div>

        {/* Co-host (Rita) — right */}
        <div class="bg-surface rounded-2xl shadow-md p-4 border border-stone-100 flex flex-col gap-3">
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
              <span class="text-lg">👤</span>
            </div>
            <div class="min-w-0">
              <p class="font-bold text-charcoal text-sm leading-tight">{property.cohost!.name}</p>
              <p class="text-stone-500 text-xs">{property.cohost!.role ?? 'Co-host'}</p>
            </div>
          </div>
          <a
            href={`tel:${formatTelLink(property.cohost!.phone)}`}
            class="flex items-center gap-2 bg-primary text-white rounded-xl px-3 py-2.5 hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-1 min-h-[48px]"
            aria-label={`Call ${property.cohost!.name}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div class="min-w-0">
              <p class="text-xs text-white/70 font-medium">Call</p>
              <p class="font-semibold text-xs truncate">{property.cohost!.phone}</p>
            </div>
          </a>
          <a
            href={`https://wa.me/${formatWhatsAppLink(property.cohost!.whatsapp)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 bg-green-500 text-white rounded-xl px-3 py-2.5 hover:bg-green-600 transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-1 min-h-[48px]"
            aria-label={`WhatsApp ${property.cohost!.name}`}
          >
            <svg class="h-4 w-4 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div class="min-w-0">
              <p class="text-xs text-white/70 font-medium">WhatsApp</p>
              <p class="font-semibold text-xs truncate">{property.cohost!.whatsapp}</p>
            </div>
          </a>
          {property.cohost!.email && (
            <a
              href={`mailto:${property.cohost!.email}`}
              class="flex items-center gap-2 bg-stone-100 text-charcoal rounded-xl px-3 py-2.5 hover:bg-stone-200 transition-colors focus:outline-none focus:ring-2 focus:ring-stone-400 focus:ring-offset-1 min-h-[48px]"
              aria-label={`Email ${property.cohost!.name}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div class="min-w-0">
                <p class="text-xs text-stone-500 font-medium">Email</p>
                <p class="font-semibold text-xs truncate">{property.cohost!.email}</p>
              </div>
            </a>
          )}
        </div>
      </div>
    ) : (
      <div class="bg-surface rounded-2xl shadow-md p-6 border border-stone-100 mb-6">
        <div class="flex items-center gap-4 mb-5">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0" aria-hidden="true">
            <span class="text-2xl">🏡</span>
          </div>
          <div>
            <p class="font-bold text-charcoal text-lg">{property.host.name}</p>
            <p class="text-stone-500 text-sm">Your Host</p>
          </div>
        </div>
        <div class="space-y-3">
          <a
            href={`tel:${formatTelLink(property.host.phone)}`}
            class="flex items-center gap-3 bg-primary text-white rounded-xl px-4 py-3.5 hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 min-h-[56px]"
            aria-label={`Call host at ${property.host.phone}`}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div>
              <p class="text-xs text-white/70 font-medium">Call</p>
              <p class="font-semibold">{property.host.phone}</p>
            </div>
          </a>
          <a
            href={`https://wa.me/${formatWhatsAppLink(property.host.whatsapp)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 bg-green-500 text-white rounded-xl px-4 py-3.5 hover:bg-green-600 transition-colors focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 min-h-[56px]"
            aria-label={`WhatsApp host at ${property.host.whatsapp}`}
          >
            <svg class="h-5 w-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <div>
              <p class="text-xs text-white/70 font-medium">WhatsApp</p>
              <p class="font-semibold">{property.host.whatsapp}</p>
            </div>
          </a>
          {property.host.email && (
            <a
              href={`mailto:${property.host.email}`}
              class="flex items-center gap-3 bg-stone-100 text-charcoal rounded-xl px-4 py-3.5 hover:bg-stone-200 transition-colors focus:outline-none focus:ring-2 focus:ring-stone-400 focus:ring-offset-2 min-h-[56px]"
              aria-label={`Email host at ${property.host.email}`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <p class="text-xs text-stone-500 font-medium">Email</p>
                <p class="font-semibold text-sm">{property.host.email}</p>
              </div>
            </a>
          )}
        </div>
      </div>
    )}

    <div id="page-bottom" class="text-center py-6">
      <p class="text-4xl mb-3" aria-hidden="true">🌅</p>
      <p class="font-serif text-xl font-semibold text-charcoal mb-2">Enjoy your stay!</p>
      <p class="text-stone-500 text-sm leading-relaxed">
        We hope this guide makes your stay even better. If you enjoy your time here, we'd be so grateful for a review on Airbnb — it means everything to us.
      </p>
    </div>
  </div>
</section>
