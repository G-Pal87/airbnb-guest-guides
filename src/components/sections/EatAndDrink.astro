---
interface EatItem {
  name: string;
  type: string;
  distance: string;
  tip: string;
  priceRange?: string;
  mapsUrl?: string;
}

interface ShopItem {
  name: string;
  distance: string;
  tip: string;
  mapsUrl?: string;
}

interface Props {
  property: {
    eatAndDrink: EatItem[];
    shopping?: ShopItem[];
  };
}

const { property } = Astro.props;
const shopping = property.shopping ?? [];

const VISIBLE_COUNT = 6;

function typeIcon(type: string): string {
  const t = type.toLowerCase();
  if (t.includes('seafood') || t.includes('fish')) return '🐟';
  if (t.includes('grocery') || t.includes('supermarket') || t.includes('market')) return '🛒';
  if (t.includes('café') || t.includes('cafe') || t.includes('coffee') || t.includes('brunch')) return '☕';
  if (t.includes('bar') || t.includes('cocktail')) return '🍹';
  if (t.includes('pizza') || t.includes('italian')) return '🍕';
  if (t.includes('food court')) return '🏬';
  if (t.includes('cypriot') || t.includes('greek') || t.includes('meze') || t.includes('grill') || t.includes('tavern')) return '🍽️';
  if (t.includes('wine')) return '🍷';
  if (t.includes('bakery') || t.includes('pastry')) return '🥐';
  if (t.includes('snack') || t.includes('kiosk')) return '🍦';
  return '🍴';
}

function priceRangeColor(range: string): string {
  switch (range) {
    case '€': return 'bg-green-100 text-green-700';
    case '€€': return 'bg-amber-100 text-amber-700';
    case '€€€': return 'bg-orange-100 text-orange-700';
    default: return 'bg-stone-100 text-stone-600';
  }
}
---

<section id="eat-drink" class="py-12 bg-surface" aria-labelledby="eat-drink-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="eat-drink-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
      Eat & Drink
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {property.eatAndDrink.map((place: EatItem, i: number) => (
        <div class={`bg-white rounded-2xl shadow-md p-4 border border-stone-100${i >= VISIBLE_COUNT ? ' eat-extra hidden' : ''}`}>
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-semibold text-charcoal text-sm leading-snug flex items-center gap-1.5">
              <span aria-hidden="true">{typeIcon(place.type)}</span>
              {place.name}
            </h3>
            <span class="flex-shrink-0 bg-primary/10 text-primary text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap">
              {place.distance}
            </span>
          </div>
          <div class="flex items-center gap-1.5 mb-2">
            <span class="text-xs bg-stone-100 text-stone-600 px-2 py-0.5 rounded-full font-medium">{place.type}</span>
            {place.priceRange && (
              <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${priceRangeColor(place.priceRange)}`}>
                {place.priceRange}
              </span>
            )}
          </div>
          <p class="text-stone-500 text-xs leading-relaxed">{place.tip}</p>
          {place.mapsUrl && (
            <a
              href={place.mapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 mt-2 text-primary text-xs font-semibold hover:underline"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Open in Maps
            </a>
          )}
        </div>
      ))}
    </div>

    {property.eatAndDrink.length > VISIBLE_COUNT && (
      <button
        type="button"
        id="eat-toggle-btn"
        data-hidden-count={property.eatAndDrink.length - VISIBLE_COUNT}
        class="mt-4 w-full flex items-center justify-center gap-2 text-primary text-sm font-semibold py-3 rounded-2xl border border-primary/30 hover:bg-primary/5 transition-colors"
      >
        <span id="eat-toggle-label">Show {property.eatAndDrink.length - VISIBLE_COUNT} more</span>
        <svg id="eat-toggle-chevron" class="h-4 w-4 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    )}

    <!-- Shopping section -->
    {shopping.length > 0 && (
      <div class="mt-10">
        <h3 class="font-serif text-2xl font-bold text-charcoal mb-5">
          Shopping 🛍️
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {shopping.map((shop: ShopItem) => (
            <div class="bg-white rounded-2xl shadow-md p-4 border border-stone-100">
              <div class="flex items-start justify-between gap-2 mb-2">
                <h4 class="font-semibold text-charcoal text-sm leading-snug flex items-center gap-1.5">
                  <span aria-hidden="true">🛍️</span>
                  {shop.name}
                </h4>
                <span class="flex-shrink-0 bg-primary/10 text-primary text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap">
                  {shop.distance}
                </span>
              </div>
              <p class="text-stone-500 text-xs leading-relaxed">{shop.tip}</p>
              {shop.mapsUrl && (
                <a
                  href={shop.mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 mt-2 text-primary text-xs font-semibold hover:underline"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Open in Maps
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<script>
  const btn = document.getElementById('eat-toggle-btn');
  if (btn) {
    const hiddenCount = parseInt(btn.getAttribute('data-hidden-count') ?? '0', 10);
    const label = document.getElementById('eat-toggle-label');
    const chevron = document.getElementById('eat-toggle-chevron') as HTMLElement | null;
    let expanded = false;

    btn.addEventListener('click', () => {
      expanded = !expanded;
      document.querySelectorAll<HTMLElement>('.eat-extra').forEach((el) => {
        el.classList.toggle('hidden', !expanded);
      });
      if (label) label.textContent = expanded ? 'Show less' : `Show ${hiddenCount} more`;
      if (chevron) chevron.style.transform = expanded ? 'rotate(180deg)' : '';
    });
  }
</script>
