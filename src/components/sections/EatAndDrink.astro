---
interface EatItem {
  name: string;
  type: string;
  distance: string;
  tip: string;
  priceRange: string;
}

interface Props {
  property: {
    eatAndDrink: EatItem[];
  };
}

const { property } = Astro.props;

function priceRangeColor(range: string): string {
  switch (range) {
    case '€': return 'bg-green-100 text-green-700';
    case '€€': return 'bg-amber-100 text-amber-700';
    case '€€€': return 'bg-orange-100 text-orange-700';
    default: return 'bg-stone-100 text-stone-600';
  }
}

function typeIcon(type: string): string {
  const t = type.toLowerCase();
  if (t.includes('seafood') || t.includes('fish')) return '🐟';
  if (t.includes('grocery') || t.includes('supermarket') || t.includes('market')) return '🛒';
  if (t.includes('café') || t.includes('cafe') || t.includes('coffee')) return '☕';
  if (t.includes('bar') || t.includes('cocktail')) return '🍹';
  if (t.includes('pizza') || t.includes('italian')) return '🍕';
  if (t.includes('cypriot') || t.includes('greek') || t.includes('meze') || t.includes('grill')) return '🍽️';
  if (t.includes('bakery') || t.includes('pastry')) return '🥐';
  if (t.includes('snack') || t.includes('kiosk')) return '🍦';
  return '🍴';
}
---

<section id="eat-drink" class="py-12 bg-surface" aria-labelledby="eat-drink-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="eat-drink-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
      Eat & Drink
    </h2>

    <div class="space-y-3">
      {property.eatAndDrink.map((place: EatItem) => (
        <div class="bg-white rounded-2xl shadow-md p-4 border border-stone-100">
          <div class="flex items-start gap-3">
            <span class="text-2xl flex-shrink-0 mt-0.5" aria-hidden="true">{typeIcon(place.type)}</span>
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1.5">
                <h3 class="font-semibold text-charcoal text-base">{place.name}</h3>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${priceRangeColor(place.priceRange)}`}>
                  {place.priceRange}
                </span>
              </div>
              <div class="flex flex-wrap items-center gap-2 mb-2">
                <span class="text-xs bg-stone-100 text-stone-600 px-2.5 py-1 rounded-full font-medium">
                  {place.type}
                </span>
                <span class="text-xs text-stone-400">•</span>
                <span class="text-xs text-stone-500 font-medium flex items-center gap-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  {place.distance}
                </span>
              </div>
              <p class="text-stone-500 text-sm leading-relaxed">{place.tip}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
