---
interface EmergencyContact {
  name: string;
  number: string;
  note: string;
}

interface Props {
  property: {
    emergency: {
      contacts: EmergencyContact[];
      nearestHospital: string;
      nearestHospitalUrl?: string;
      nearestPharmacy: string;
    };
  };
}

const { property } = Astro.props;

function formatTelLink(number: string): string {
  return number.replace(/\s/g, '');
}

function contactIcon(name: string): string {
  const n = name.toLowerCase();
  if (n.includes('emergency') || n.includes('police') || n.includes('fire')) return '🚨';
  if (n.includes('hospital') || n.includes('ambulance')) return '🏥';
  if (n.includes('host')) return '🏡';
  if (n.includes('pharmacy')) return '💊';
  if (n.includes('manager') || n.includes('supervisor')) return '🔧';
  if (n.includes('building')) return '🏢';
  return '📞';
}
---

<section id="emergency" class="py-12 bg-white" aria-labelledby="emergency-heading">
  <div class="max-w-2xl mx-auto px-4">
    <!-- Header with red accent -->
    <div class="flex items-center gap-3 mb-8">
      <span class="text-3xl" aria-hidden="true">🚨</span>
      <h2 id="emergency-heading" class="font-serif text-3xl font-bold text-red-700" data-i18n="ui.emergency">
        Emergency Contacts
      </h2>
    </div>

    <!-- Alert bar -->
    <div class="bg-red-50 border-l-4 border-red-500 rounded-r-2xl px-4 py-3 mb-6 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
      <p class="text-red-800 text-sm font-medium">
        All numbers below are tap-to-call. In a life-threatening emergency, always call <strong>112</strong> first.
      </p>
    </div>

    <!-- Contacts -->
    <div class="space-y-3 mb-8">
      {property.emergency.contacts.map((contact: EmergencyContact, ci: number) => (
        <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-red-500 focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">{contactIcon(contact.name)}</span>
            <span class="font-semibold text-charcoal flex-1">{contact.name}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4">
              <p class="text-stone-500 text-xs mb-3 leading-relaxed" data-i18n={`emergency.contacts.${ci}.note`}>{contact.note}</p>
              <a
                href={`tel:${formatTelLink(contact.number)}`}
                class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-bold text-base px-4 py-2.5 rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-red-600 focus:ring-offset-2 min-h-[44px]"
                aria-label={`Call ${contact.name} at ${contact.number}`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {contact.number}
              </a>
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- Nearby services -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      <div class="bg-blue-50 border border-blue-200 rounded-2xl p-4">
        <div class="flex items-start gap-2">
          <span class="text-xl flex-shrink-0" aria-hidden="true">🏥</span>
          <div>
            <p class="font-semibold text-blue-900 text-sm mb-1" data-i18n="ui.nearestHospital">Nearest Hospital</p>
            <p class="text-blue-700 text-xs leading-relaxed">{property.emergency.nearestHospital}</p>
            {property.emergency.nearestHospitalUrl && (
              <a
                href={property.emergency.nearestHospitalUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 mt-2 text-blue-700 text-xs font-semibold hover:underline"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Open in Google Maps
              </a>
            )}
          </div>
        </div>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-2xl p-4">
        <div class="flex items-start gap-2">
          <span class="text-xl flex-shrink-0" aria-hidden="true">💊</span>
          <div>
            <p class="font-semibold text-green-900 text-sm mb-1" data-i18n="ui.nearestPharmacy">Nearest Pharmacy</p>
            <p class="text-green-700 text-xs leading-relaxed" data-i18n="emergency.nearestPharmacy">{property.emergency.nearestPharmacy}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
