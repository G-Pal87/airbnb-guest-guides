---
interface GettingAroundItem {
  icon: string;
  name: string;
  info: string;
  linkText?: string;
  linkUrl?: string;
}

interface Props {
  property: {
    gettingAround?: GettingAroundItem[];
  };
}

const { property } = Astro.props;
const items = property.gettingAround ?? [];
---

{items.length > 0 && (
  <section id="getting-around" class="py-12 bg-white" aria-labelledby="getting-around-heading">
    <div class="max-w-2xl mx-auto px-4">
      <h2 id="getting-around-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
        Getting Around
      </h2>
      <div class="space-y-3">
        {items.map((item: GettingAroundItem) => (
          <div class="bg-surface rounded-2xl shadow-md p-5 border border-stone-100">
            <div class="flex items-start gap-3">
              <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">{item.icon}</span>
              <div>
                <h3 class="font-semibold text-charcoal mb-1">{item.name}</h3>
                <p class="text-stone-600 text-sm leading-relaxed">{item.info}</p>
                {item.linkUrl && item.linkText && (
                  <a
                    href={item.linkUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 mt-2 text-primary text-xs font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-1 rounded min-h-[44px]"
                  >
                    {item.linkText} →
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}
