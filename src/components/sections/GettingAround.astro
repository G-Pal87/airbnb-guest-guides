---
interface GettingAroundItem {
  icon: string;
  name: string;
  info: string;
  linkText?: string;
  linkUrl?: string;
}

interface Props {
  property: {
    gettingAround?: GettingAroundItem[];
  };
}

const { property } = Astro.props;
const items = property.gettingAround ?? [];
---

{items.length > 0 && (
  <section id="getting-around" class="py-12 bg-white" aria-labelledby="getting-around-heading">
    <div class="max-w-2xl mx-auto px-4">
      <h2 id="getting-around-heading" class="font-serif text-3xl font-bold text-charcoal mb-8" data-i18n="ui.gettingAround">
        Getting Around
      </h2>
      <div class="space-y-3">
        {items.map((item: GettingAroundItem, idx: number) => (
          <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
            <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
              <span class="text-2xl flex-shrink-0" aria-hidden="true">{item.icon}</span>
              <span class="font-semibold text-charcoal flex-1" data-i18n={`gettingAround.${idx}.name`}>{item.name}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-1">
              <div class="border-t border-stone-100 pt-4">
                <p class="text-stone-600 text-sm leading-relaxed" data-i18n={`gettingAround.${idx}.info`}>{item.info}</p>
                {item.linkUrl && item.linkText && (
                  <a
                    href={item.linkUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 mt-3 text-primary text-xs font-semibold hover:underline focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-1 rounded"
                  >
                    {item.linkText} →
                  </a>
                )}
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
