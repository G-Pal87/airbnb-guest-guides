---
interface DirectionPhoto {
  src: string;
  caption: string;
}

interface GettingAroundItem {
  icon: string;
  name: string;
  info: string;
  linkText?: string;
  linkUrl?: string;
}

interface Props {
  property: {
    address: {
      display: string;
      googleMapsUrl: string;
      nearestLandmark: string;
      addressNote?: string;
    };
    gettingHere: {
      directions?: string;
      byCar?: string;
      parking: string;
      publicTransport: string;
      busStationUrl?: string;
      taxi?: string;
      directionPhotos?: DirectionPhoto[];
    };
    gettingAround?: GettingAroundItem[];
  };
}

const { property } = Astro.props;
const directions = property.gettingHere.byCar ?? property.gettingHere.directions ?? '';
const photos = property.gettingHere.directionPhotos ?? [];
const gettingAround = property.gettingAround ?? [];
---

<section id="getting-here" class="py-12 bg-white" aria-labelledby="getting-here-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="getting-here-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
      Getting Here
    </h2>

    <!-- Address card -->
    <div class="bg-surface rounded-2xl shadow-md p-5 mb-6 border border-stone-100">
      <div class="flex items-start gap-3">
        <span class="text-2xl flex-shrink-0 mt-0.5" aria-hidden="true">📍</span>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-charcoal text-base leading-snug">
            {property.address.display}
          </p>
          <p class="text-sm text-stone-500 mt-1">
            {property.address.nearestLandmark}
          </p>
          {property.address.addressNote && (
            <p class="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 mt-3">
              ⚠️ {property.address.addressNote}
            </p>
          )}
          <a
            href={property.address.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-3 bg-primary text-white text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 min-h-[44px]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Open in Google Maps
          </a>
        </div>
      </div>
    </div>

    <!-- Info cards -->
    <div class="space-y-4">
      <!-- By Car + Parking -->
      {directions && (
        <div class="bg-surface rounded-2xl shadow-md p-5 border border-stone-100">
          <div class="flex items-start gap-3">
            <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">🚗</span>
            <div class="flex-1">
              <h3 class="font-semibold text-charcoal mb-1.5">By Car</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{directions}</p>
              {photos.length >= 4 && (
                <a
                  href="#photo-guide"
                  class="inline-flex items-center gap-1.5 mt-3 bg-amber-50 text-amber-700 border border-amber-200 text-xs font-semibold px-3 py-1.5 rounded-full hover:bg-amber-100 transition-colors"
                >
                  📸 See photos 4 onwards below
                </a>
              )}
            </div>
          </div>
          <div class="border-t border-stone-100 mt-4 pt-4 flex items-start gap-3">
            <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">🅿️</span>
            <div class="flex-1">
              <h3 class="font-semibold text-charcoal mb-1.5">Parking</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{property.gettingHere.parking}</p>
            </div>
          </div>
        </div>
      )}

      <!-- Public Transport -->
      <div class="bg-surface rounded-2xl shadow-md p-5 border border-stone-100">
        <div class="flex items-start gap-3">
          <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">🚌</span>
          <div class="flex-1">
            <h3 class="font-semibold text-charcoal mb-1.5">By Public Transport</h3>
            <p class="text-stone-600 text-sm leading-relaxed">{property.gettingHere.publicTransport}</p>
            {property.gettingHere.busStationUrl && (
              <a
                href={property.gettingHere.busStationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 mt-3 text-primary text-xs font-semibold hover:underline"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Tombs of the Kings Bus Station →
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Taxi (optional) -->
      {property.gettingHere.taxi && (
        <div class="bg-surface rounded-2xl shadow-md p-5 border border-stone-100">
          <div class="flex items-start gap-3">
            <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">🚕</span>
            <div>
              <h3 class="font-semibold text-charcoal mb-1.5">Taxi</h3>
              <p class="text-stone-600 text-sm leading-relaxed">{property.gettingHere.taxi}</p>
            </div>
          </div>
        </div>
      )}

      <!-- Photo walkthrough -->
      {photos.length > 0 && (
        <div id="photo-guide" class="bg-surface rounded-2xl shadow-md p-5 border border-stone-100">
          <h3 class="font-semibold text-charcoal mb-4 flex items-center gap-2">
            <span aria-hidden="true">📸</span> Step-by-Step Photo Guide
          </h3>
          <div class="space-y-4">
            {photos.map((photo: DirectionPhoto, i: number) => (
              <div class="flex items-start gap-3">
                <span
                  class="flex-shrink-0 w-7 h-7 rounded-full bg-primary text-white font-bold text-xs flex items-center justify-center mt-1"
                  aria-hidden="true"
                >
                  {i + 1}
                </span>
                <div class="flex-1 min-w-0">
                  <img
                    src={photo.src}
                    alt={photo.caption}
                    loading="lazy"
                    class="w-full rounded-xl object-contain mb-2"
                  />
                  <p class="text-stone-600 text-sm leading-relaxed">{photo.caption}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

  </div>
</section>
