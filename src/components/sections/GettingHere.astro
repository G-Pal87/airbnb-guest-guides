---
interface DirectionPhoto {
  src: string;
  caption: string;
}

interface GettingAroundItem {
  icon: string;
  name: string;
  info: string;
  linkText?: string;
  linkUrl?: string;
}

interface Props {
  property: {
    address: {
      display: string;
      googleMapsUrl: string;
      nearestLandmark: string;
      addressNote?: string;
    };
    gettingHere: {
      directions?: string;
      byCar?: string;
      parking: string;
      publicTransport: string;
      busStationUrl?: string;
      taxi?: string;
      directionPhotos?: DirectionPhoto[];
      directionPhotosStart?: number;
    };
    gettingAround?: GettingAroundItem[];
  };
}

const { property } = Astro.props;
const directions = property.gettingHere.byCar ?? property.gettingHere.directions ?? '';
const photos = property.gettingHere.directionPhotos ?? [];
const gettingAround = property.gettingAround ?? [];
const photoStart = property.gettingHere.directionPhotosStart ?? 1;
---

<section id="getting-here" class="py-12 bg-white" aria-labelledby="getting-here-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="getting-here-heading" class="font-serif text-3xl font-bold text-charcoal mb-8" data-i18n="ui.gettingHere">
      Getting Here
    </h2>

    <!-- Address card — always visible -->
    <div class="bg-surface rounded-2xl shadow-md p-5 mb-6 border border-stone-100">
      <div class="flex items-start gap-3">
        <span class="text-2xl flex-shrink-0 mt-0.5" aria-hidden="true">📍</span>
        <div class="flex-1 min-w-0">
          <p class="font-semibold text-charcoal text-base leading-snug">
            {property.address.display}
          </p>
          <p class="text-sm text-stone-500 mt-1">
            {property.address.nearestLandmark}
          </p>
          {property.address.addressNote && (
            <p class="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-3 py-2 mt-3">
              ⚠️ {property.address.addressNote}
            </p>
          )}
          <a
            href={property.address.googleMapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-3 bg-primary text-white text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-teal-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 min-h-[44px]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span data-i18n="ui.openGoogleMaps">Open in Google Maps</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Transport accordions -->
    <div class="space-y-3">
      <!-- By Car + Parking -->
      {directions && (
        <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">🚗</span>
            <span class="font-semibold text-charcoal flex-1" data-i18n="ui.byCar">By Car & Parking</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4 space-y-4">
              <div>
                <p class="text-stone-600 text-sm leading-relaxed" data-i18n="gettingHere.byCar">{directions}</p>
                {photos.length > 0 && (
                  <a
                    href={`#direction-photo-${photoStart}`}
                    class="inline-flex items-center gap-1.5 mt-3 bg-amber-50 text-amber-700 border border-amber-200 text-xs font-semibold px-3 py-1.5 rounded-full hover:bg-amber-100 transition-colors"
                  >
                    📸 See photos {photoStart} onwards below
                  </a>
                )}
              </div>
              <div class="border-t border-stone-100 pt-4 flex items-start gap-3">
                <span class="text-xl flex-shrink-0 mt-0.5" aria-hidden="true">🅿️</span>
                <div>
                  <p class="font-semibold text-charcoal text-sm mb-1" data-i18n="ui.parking">Parking</p>
                  <p class="text-stone-600 text-sm leading-relaxed" data-i18n="gettingHere.parking">{property.gettingHere.parking}</p>
                </div>
              </div>
            </div>
          </div>
        </details>
      )}

      <!-- Public Transport -->
      <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
        <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
          <span class="text-2xl flex-shrink-0" aria-hidden="true">🚌</span>
          <span class="font-semibold text-charcoal flex-1" data-i18n="ui.publicTransport">By Public Transport</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="px-5 pb-5 pt-1">
          <div class="border-t border-stone-100 pt-4">
            <p class="text-stone-600 text-sm leading-relaxed" data-i18n="gettingHere.publicTransport">{property.gettingHere.publicTransport}</p>
            {property.gettingHere.busStationUrl && (
              <a
                href={property.gettingHere.busStationUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 mt-3 text-primary text-xs font-semibold hover:underline"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Tombs of the Kings Bus Station →
              </a>
            )}
          </div>
        </div>
      </details>

      <!-- Taxi -->
      {property.gettingHere.taxi && (
        <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">🚕</span>
            <span class="font-semibold text-charcoal flex-1" data-i18n="ui.taxi">Taxi</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4">
              <p class="text-stone-600 text-sm leading-relaxed" data-i18n="gettingHere.taxi">{property.gettingHere.taxi}</p>
            </div>
          </div>
        </details>
      )}

      <!-- Photo walkthrough -->
      {photos.length > 0 && (
        <details id="photo-guide" class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">📸</span>
            <span class="font-semibold text-charcoal flex-1" data-i18n="ui.photoGuide">Step-by-Step Photo Guide</span>
            <span class="flex-shrink-0 bg-primary/10 text-primary text-xs font-semibold px-2.5 py-1 rounded-full mr-2">
              {photos.length}
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4 space-y-4">
              {photos.map((photo: DirectionPhoto, i: number) => (
                <div id={`direction-photo-${i + 1}`} class="flex items-start gap-3">
                  <span
                    class="flex-shrink-0 w-7 h-7 rounded-full bg-primary text-white font-bold text-xs flex items-center justify-center mt-1"
                    aria-hidden="true"
                  >
                    {i + 1}
                  </span>
                  <div class="flex-1 min-w-0">
                    <img
                      src={photo.src}
                      alt={photo.caption}
                      loading="lazy"
                      class="w-full rounded-xl object-contain mb-2"
                    />
                    <p class="text-stone-600 text-sm leading-relaxed" data-i18n={`gettingHere.directionPhotos.${i}.caption`}>{photo.caption}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>
      )}
    </div>

  </div>
</section>
