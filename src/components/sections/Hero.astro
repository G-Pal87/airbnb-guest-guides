---
interface Props {
  property: {
    name: string;
    subtitle: string;
    tagline: string;
    heroImage: string;
    welcomeMessage: string;
  };
}

const { property } = Astro.props;
const hasHeroImage = property.heroImage && property.heroImage.trim() !== '';
---

<section aria-label="Hero">
  <!-- Hero banner -->
  <div
    class={`relative w-full min-h-[60vh] flex items-end ${hasHeroImage ? '' : 'bg-gradient-to-br from-primary to-teal-800'}`}
    style={hasHeroImage ? `background-image: url('${property.heroImage}'); background-size: cover; background-position: center;` : ''}
  >
    {hasHeroImage && (
      <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
    )}

    <!-- Decorative pattern overlay for gradient hero -->
    {!hasHeroImage && (
      <div class="absolute inset-0 opacity-10" aria-hidden="true">
        <div class="absolute top-10 left-10 w-32 h-32 rounded-full bg-white/30 blur-2xl"></div>
        <div class="absolute bottom-20 right-20 w-48 h-48 rounded-full bg-accent/30 blur-3xl"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-teal-300/20 blur-3xl"></div>
      </div>
    )}

    <div class="relative z-10 w-full max-w-2xl mx-auto px-4 pb-12 pt-20">
      <!-- Property name -->
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white leading-tight mb-2 drop-shadow-md">
        {property.name}
      </h1>
      <!-- Subtitle -->
      {property.subtitle && (
        <p class="text-accent font-semibold text-lg md:text-xl mb-3 drop-shadow">
          {property.subtitle}
        </p>
      )}
      <!-- Tagline -->
      {property.tagline && (
        <p class="text-white/90 text-base md:text-lg italic drop-shadow">
          {property.tagline}
        </p>
      )}
    </div>
  </div>

  <!-- Welcome message card -->
  <div class="bg-white">
    <div class="max-w-2xl mx-auto px-4 py-8">
      <div class="bg-surface rounded-2xl shadow-md p-6 border border-stone-100">
        <div class="flex items-start gap-3">
          <span class="text-2xl flex-shrink-0 mt-0.5" aria-hidden="true">🌊</span>
          <div>
            <h2 class="font-serif text-xl font-semibold text-charcoal mb-2" data-i18n="ui.welcome">
              Welcome!
            </h2>
            <p class="text-stone-600 leading-relaxed text-base" data-i18n="welcomeMessage">
              {property.welcomeMessage}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
