---
interface Props {
  property: {
    name: string;
    subtitle: string;
    tagline: string;
    heroImage: string;
    welcomeMessage: string;
  };
}

const { property } = Astro.props;
const hasHeroImage = property.heroImage && property.heroImage.trim() !== '';
---

<section aria-label="Hero">
  <!-- Hero banner -->
  <div
    class={`relative w-full min-h-[80vh] flex items-end ${hasHeroImage ? '' : 'bg-gradient-to-br from-teal-900 via-primary to-cyan-700'}`}
    style={hasHeroImage ? `background-image: url('${property.heroImage}'); background-size: cover; background-position: center;` : ''}
  >
    <!-- Bottom-heavy gradient overlay for text legibility -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-transparent" aria-hidden="true"></div>

    <!-- Decorative blobs for no-image fallback -->
    {!hasHeroImage && (
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-12 left-12 w-48 h-48 rounded-full bg-cyan-400/20 blur-3xl"></div>
        <div class="absolute bottom-32 right-16 w-64 h-64 rounded-full bg-accent/20 blur-3xl"></div>
        <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-80 h-80 rounded-full bg-teal-300/10 blur-3xl"></div>
      </div>
    )}

    <div class="relative z-10 w-full max-w-2xl mx-auto px-6 pb-20 pt-24">
      <!-- Eyebrow -->
      <p class="text-accent/90 text-xs font-semibold uppercase tracking-[0.2em] mb-4">Guest Guide</p>
      <!-- Property name -->
      <h1 class="font-serif text-5xl md:text-6xl font-bold text-white leading-tight mb-3" style="text-shadow: 0 2px 16px rgba(0,0,0,0.4)">
        {property.name}
      </h1>
      <!-- Subtitle -->
      {property.subtitle && (
        <p class="text-accent font-semibold text-lg md:text-xl mb-2 drop-shadow" data-i18n="subtitle">
          {property.subtitle}
        </p>
      )}
      <!-- Tagline -->
      {property.tagline && (
        <p class="text-white/75 text-base md:text-lg font-light italic" data-i18n="tagline">
          {property.tagline}
        </p>
      )}
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1" aria-hidden="true">
      <span class="text-white/40 text-[10px] font-medium uppercase tracking-widest">Scroll</span>
      <svg class="h-5 w-5 text-white/40 animate-bounce" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>

  <!-- Welcome card -->
  <div class="bg-white">
    <div class="max-w-2xl mx-auto px-4 py-8">
      <div class="relative bg-surface rounded-2xl shadow-lg p-6 border border-stone-100 overflow-hidden">
        <!-- Teal left accent bar -->
        <div class="absolute left-0 top-0 bottom-0 w-1 rounded-l-2xl" style="background: linear-gradient(to bottom, #0E7490, #06B6D4)"></div>
        <div class="flex items-start gap-3 pl-3">
          <span class="text-2xl flex-shrink-0 mt-0.5" aria-hidden="true">🌊</span>
          <div>
            <h2 class="font-serif text-xl font-semibold text-charcoal mb-2" data-i18n="ui.welcome">
              Welcome!
            </h2>
            <p class="text-stone-600 leading-relaxed text-base" data-i18n="welcomeMessage">
              {property.welcomeMessage}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
