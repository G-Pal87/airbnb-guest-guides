---
interface Props {
  property: {
    houseRules: string[];
  };
}

const { property } = Astro.props;

function ruleIcon(rule: string): string {
  const r = rule.toLowerCase();
  if (r.includes('smok')) return '🚭';
  if (r.includes('party') || r.includes('parties') || r.includes('quiet') || r.includes('noise')) return '🔇';
  if (r.includes('occupancy') || r.includes('maximum') && r.includes('guest')) return '👥';
  if (r.includes('pet')) return '🐾';
  if (r.includes('kitchen') || r.includes('dishes') || r.includes('insect') || r.includes('counter')) return '🍽️';
  if (r.includes('toilet') || r.includes('flush') || r.includes('plumbing')) return '🚽';
  if (r.includes('pool')) return '🏊';
  if (r.includes('air con') || r.includes('balcony') || r.includes('window')) return '❄️';
  if (r.includes('key') || r.includes('locksmith')) return '🔑';
  if (r.includes('breakage') || r.includes('report') || r.includes('treat the')) return '🏠';
  return '✅';
}

function ruleTitle(rule: string): string {
  const r = rule.toLowerCase();
  if (r.includes('smok')) return 'No Smoking';
  if (r.includes('quiet') || r.includes('noise')) return 'Quiet Hours';
  if (r.includes('party') || r.includes('parties')) return 'No Parties or Events';
  if (r.includes('occupancy') || r.includes('maximum') && r.includes('guest')) return 'Max Occupancy';
  if (r.includes('pet')) return 'No Pets';
  if (r.includes('kitchen') || r.includes('dishes') || r.includes('insect') || r.includes('counter')) return 'Kitchen';
  if (r.includes('toilet') || r.includes('flush') || r.includes('plumbing')) return 'Plumbing';
  if (r.includes('pool')) return 'Pool Rules';
  if (r.includes('air con') || r.includes('balcony') || r.includes('window')) return 'AC & Windows';
  if (r.includes('locksmith') || r.includes('lose') && r.includes('key')) return 'Lost Keys';
  if (r.includes('key') || r.includes('keybox')) return 'Keys';
  if (r.includes('breakage') || r.includes('report') || r.includes('treat the')) return 'Property Care';
  return rule.split(/[.!]/)[0].slice(0, 45);
}

function ruleI18nKey(rule: string): string {
  const r = rule.toLowerCase();
  if (r.includes('smok')) return 'ui.ruleTitleNoSmoking';
  if (r.includes('quiet') || r.includes('noise')) return 'ui.ruleTitleQuietHours';
  if (r.includes('party') || r.includes('parties')) return 'ui.ruleTitleNoParties';
  if (r.includes('occupancy') || r.includes('maximum') && r.includes('guest')) return 'ui.ruleTitleMaxOccupancy';
  if (r.includes('pet')) return 'ui.ruleTitleNoPets';
  if (r.includes('kitchen') || r.includes('dishes') || r.includes('insect') || r.includes('counter')) return 'ui.ruleTitleKitchen';
  if (r.includes('toilet') || r.includes('flush') || r.includes('plumbing')) return 'ui.ruleTitlePlumbing';
  if (r.includes('pool')) return 'ui.ruleTitlePool';
  if (r.includes('air con') || r.includes('balcony') || r.includes('window')) return 'ui.ruleTitleACWindows';
  if (r.includes('locksmith') || r.includes('lose') && r.includes('key')) return 'ui.ruleTitleLostKeys';
  if (r.includes('key') || r.includes('keybox')) return 'ui.ruleTitleKeys';
  if (r.includes('breakage') || r.includes('report') || r.includes('treat the')) return 'ui.ruleTitlePropertyCare';
  return '';
}
---

<section id="house-rules" class="py-12 bg-white" aria-labelledby="house-rules-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="house-rules-heading" class="font-serif text-3xl font-bold text-charcoal mb-8" data-i18n="ui.houseRules">
      House Rules
    </h2>

    <div class="space-y-3">
      {property.houseRules.map((rule: string, i: number) => (
        <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">{ruleIcon(rule)}</span>
            <span class="font-semibold text-charcoal flex-1" data-i18n={ruleI18nKey(rule)}>{ruleTitle(rule)}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4">
              <p class="text-stone-600 text-sm leading-relaxed" data-i18n={`houseRules.${i}`}>{rule}</p>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
