---
interface Props {
  property: {
    wifi: { networkName: string; networkNames?: string[]; password: string };
    quickRef: { checkoutTime: string; emergencyPhone: string; checkinTime: string };
    cohost?: unknown;
  };
}

const { property } = Astro.props;
const hasCohost = !!property.cohost;
---

<section class="relative bg-gradient-to-br from-teal-800 via-primary to-cyan-600 py-10 overflow-hidden" aria-labelledby="quickref-heading">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-8 -right-8 w-48 h-48 rounded-full bg-white/5 blur-2xl"></div>
    <div class="absolute -bottom-8 -left-8 w-56 h-56 rounded-full bg-accent/10 blur-3xl"></div>
  </div>
  <div class="relative max-w-2xl mx-auto px-4">
    <h2 id="quickref-heading" class="font-serif text-2xl font-bold text-white mb-6 text-center" data-i18n="ui.atAGlance">
      At a Glance
    </h2>

    <div class="grid grid-cols-2 gap-3">
      <!-- Check-in -->
      <div class="bg-white/20 backdrop-blur-md rounded-2xl p-4 text-white shadow-lg border border-white/10">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xl" aria-hidden="true">🏠</span>
          <span class="text-sm font-semibold text-white/80 uppercase tracking-wide" data-i18n="ui.checkIn">Check-in</span>
        </div>
        <p class="font-bold text-2xl text-accent">
          {property.quickRef.checkinTime}
        </p>
        <p class="text-xs text-white/70 mt-1" data-i18n="ui.checkInNote">From this time onwards</p>
      </div>

      <!-- Checkout -->
      <div class="bg-white/20 backdrop-blur-md rounded-2xl p-4 text-white shadow-lg border border-white/10">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xl" aria-hidden="true">🕙</span>
          <span class="text-sm font-semibold text-white/80 uppercase tracking-wide" data-i18n="ui.checkout">Checkout</span>
        </div>
        <p class="font-bold text-2xl text-accent">
          {property.quickRef.checkoutTime}
        </p>
        <p class="text-xs text-white/70 mt-1" data-i18n="ui.checkoutNote">Please be out by this time</p>
      </div>

      <!-- WiFi -->
      <div class="bg-white/20 backdrop-blur-md rounded-2xl p-4 text-white shadow-lg border border-white/10">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-xl" aria-hidden="true">📶</span>
          <span class="text-sm font-semibold text-white/80 uppercase tracking-wide">WiFi</span>
        </div>
        {property.wifi.networkNames && property.wifi.networkNames.length > 1 ? (
          <div class="space-y-0.5">
            {property.wifi.networkNames.map((n: string) => (
              <p class="font-medium text-xs truncate" title={n}>{n}</p>
            ))}
          </div>
        ) : (
          <p class="font-medium text-xs truncate" title={property.wifi.networkName}>
            {property.wifi.networkName}
          </p>
        )}
        <div class="flex items-center gap-2 mt-1">
          <p
            id="wifi-password-quickref"
            class="font-mono text-accent font-bold text-sm break-all"
          >
            {property.wifi.password}
          </p>
          <button
            data-copy-target="wifi-password-quickref"
            class="copy-btn flex-shrink-0 bg-white/20 hover:bg-white/30 rounded-lg p-1.5 transition-colors"
            aria-label="Copy WiFi password"
            title="Copy password"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
        <p id="copy-feedback-quickref" class="text-xs text-accent mt-1 opacity-0 transition-opacity duration-300" data-i18n="ui.copied">Copied!</p>
      </div>

      <!-- Contact Us -->
      <div class="bg-white/20 backdrop-blur-md rounded-2xl p-4 text-white shadow-lg border border-white/10 flex flex-col justify-between">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl" aria-hidden="true">📞</span>
          <span class="text-sm font-semibold text-white/80 uppercase tracking-wide" data-i18n="ui.contacts">Contacts</span>
        </div>
        <p class="text-xs text-white/70 mb-3 leading-relaxed" data-i18n={hasCohost ? "ui.contactsNoteCohost" : "ui.contactsNoteSolo"}>
          {hasCohost
            ? "Need help? We're always available."
            : "Need help? I'm always available! Contact me."}
        </p>
        <a
          href="#page-bottom"
          class="inline-flex items-center justify-center gap-2 bg-accent text-charcoal text-sm font-bold px-4 py-2.5 rounded-xl shadow-md hover:bg-yellow-300 hover:shadow-lg transition-all min-h-[44px]"
        >
          <span data-i18n={hasCohost ? "ui.contactUsCohost" : "ui.contactUsSolo"}>{hasCohost ? 'Contact Us' : 'Contact Me'}</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-copy-target');
      if (!targetId) return;
      const targetEl = document.getElementById(targetId);
      if (!targetEl) return;
      const text = targetEl.textContent?.trim() ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const feedbackId = targetId.replace('wifi-password', 'copy-feedback');
        const feedback = document.getElementById(feedbackId);
        if (feedback) {
          feedback.classList.remove('opacity-0');
          setTimeout(() => feedback.classList.add('opacity-0'), 2000);
        }
        const origHtml = btn.innerHTML;
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;
        setTimeout(() => { btn.innerHTML = origHtml; }, 2000);
      } catch {
        const range = document.createRange();
        range.selectNode(targetEl);
        window.getSelection()?.removeAllRanges();
        window.getSelection()?.addRange(range);
      }
    });
  });
</script>
