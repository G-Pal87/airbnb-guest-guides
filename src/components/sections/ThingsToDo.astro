---
interface ActivityItem {
  name: string;
  distance: string;
  tip: string;
  mapsUrl?: string;
  type?: string;
  priceRange?: string;
}

interface ActivityCategory {
  category: string;
  icon?: string;
  description?: string;
  items: ActivityItem[];
}

interface Props {
  property: {
    thingsToDo: ActivityCategory[];
  };
}

const { property } = Astro.props;

const CATEGORY_ICONS: Record<string, string> = {
  'Beaches': '🏝️',
  'Historical Sites & Scenic Walks': '🏰',
  'Attractions & Excursions': '📸',
  'Hiking & Nature Trails': '⛰️',
  'Eat & Drink': '🍽️',
  'Shopping': '🛍️',
};

function getCategoryIcon(category: string): string {
  for (const [key, icon] of Object.entries(CATEGORY_ICONS)) {
    if (category.startsWith(key)) return icon;
  }
  return '✨';
}

function stripEmoji(text: string): string {
  return text.replace(/[\u{1F300}-\u{1FAFF}\u{2600}-\u{26FF}\u{2700}-\u{27BF}]/gu, '').trim();
}

function typeIcon(type: string): string {
  const t = type.toLowerCase();
  if (t.includes('seafood') || t.includes('fish')) return '🐟';
  if (t.includes('grocery') || t.includes('supermarket') || t.includes('market')) return '🛒';
  if (t.includes('café') || t.includes('cafe') || t.includes('coffee') || t.includes('brunch')) return '☕';
  if (t.includes('bar') || t.includes('cocktail')) return '🍹';
  if (t.includes('pizza') || t.includes('italian')) return '🍕';
  if (t.includes('food court')) return '🏬';
  if (t.includes('cypriot') || t.includes('greek') || t.includes('meze') || t.includes('grill') || t.includes('tavern')) return '🍽️';
  if (t.includes('wine')) return '🍷';
  if (t.includes('bakery') || t.includes('pastry')) return '🥐';
  if (t.includes('snack') || t.includes('kiosk')) return '🍦';
  return '🍴';
}

function priceRangeColor(range: string): string {
  switch (range) {
    case '€': return 'bg-green-100 text-green-700';
    case '€€': return 'bg-amber-100 text-amber-700';
    case '€€€': return 'bg-orange-100 text-orange-700';
    default: return 'bg-stone-100 text-stone-600';
  }
}
---

<section id="things-to-do" class="py-12 bg-white" aria-labelledby="things-to-do-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="things-to-do-heading" class="font-serif text-3xl font-bold text-charcoal mb-8" data-i18n="ui.thingsToDo">
      Things To Do
    </h2>

    <div class="space-y-3">
      {property.thingsToDo.map((group: ActivityCategory, gi: number) => (
        <details class="bg-white rounded-2xl shadow-md border border-stone-100 group">
          <summary class="flex items-center gap-3 px-5 py-4 cursor-pointer list-none select-none min-h-[56px] focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset rounded-2xl">
            <span class="text-2xl flex-shrink-0" aria-hidden="true">{group.icon ?? getCategoryIcon(group.category)}</span>
            <span class="font-semibold text-charcoal flex-1" data-i18n={`thingsToDo.${gi}.category`}>
              {stripEmoji(group.category)}
            </span>
            <span class="flex-shrink-0 bg-primary/10 text-primary text-xs font-semibold px-2.5 py-1 rounded-full mr-2">
              {group.items.length}
            </span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 text-stone-400 flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-1">
            <div class="border-t border-stone-100 pt-4 space-y-3">
              {group.description && (
                <p class="text-stone-500 text-xs leading-relaxed" data-i18n={`thingsToDo.${gi}.description`}>
                  {group.description}
                </p>
              )}
              {group.items.map((item: ActivityItem, i: number) => (
                <div class="flex items-start gap-3">
                  <span
                    class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/10 text-primary font-bold text-xs flex items-center justify-center mt-0.5"
                    aria-hidden="true"
                  >
                    {item.type ? typeIcon(item.type) : i + 1}
                  </span>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-2 flex-wrap">
                      <p class="font-semibold text-charcoal text-sm leading-snug" data-i18n={`thingsToDo.${gi}.items.${i}.name`}>
                        {item.name}
                      </p>
                      <span class="flex-shrink-0 bg-stone-100 text-stone-500 text-xs font-medium px-2 py-0.5 rounded-full whitespace-nowrap">
                        {item.distance}
                      </span>
                    </div>
                    {item.type && (
                      <div class="flex items-center gap-1.5 mt-1">
                        <span class="text-xs bg-stone-100 text-stone-600 px-2 py-0.5 rounded-full font-medium">{item.type}</span>
                        {item.priceRange && (
                          <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${priceRangeColor(item.priceRange)}`}>
                            {item.priceRange}
                          </span>
                        )}
                      </div>
                    )}
                    <p class="text-stone-500 text-xs leading-relaxed mt-1" data-i18n={`thingsToDo.${gi}.items.${i}.tip`}>
                      {item.tip}
                    </p>
                    {item.mapsUrl && (
                      <a
                        href={item.mapsUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 mt-1.5 text-primary text-xs font-semibold hover:underline"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        Open in Maps
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
