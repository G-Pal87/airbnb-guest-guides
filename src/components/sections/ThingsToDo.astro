---
interface ActivityItem {
  name: string;
  distance: string;
  tip: string;
  mapsUrl?: string;
}

interface ActivityCategory {
  category: string;
  items: ActivityItem[];
}

interface Props {
  property: {
    thingsToDo: ActivityCategory[];
  };
}

const { property } = Astro.props;

const categoryIcons: Record<string, string> = {
  'Beaches': '🏖️',
  'Sightseeing': '🏛️',
  'Activities': '🤿',
};

function getCategoryIcon(category: string): string {
  return categoryIcons[category] ?? '✨';
}

const VISIBLE_COUNT = 6;
---

<section id="things-to-do" class="py-12 bg-white" aria-labelledby="things-to-do-heading">
  <div class="max-w-2xl mx-auto px-4">
    <h2 id="things-to-do-heading" class="font-serif text-3xl font-bold text-charcoal mb-8">
      Things To Do
    </h2>

    <div class="space-y-8">
      {property.thingsToDo.map((group: ActivityCategory, gi: number) => (
        <div>
          <h3 class="font-serif text-xl font-semibold text-primary mb-4 flex items-center gap-2">
            <span aria-hidden="true">{getCategoryIcon(group.category)}</span>
            {group.category}
          </h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3" data-group={gi}>
            {group.items.map((item: ActivityItem, i: number) => (
              <div
                class={`bg-surface rounded-2xl shadow-md p-4 border border-stone-100${i >= VISIBLE_COUNT ? ' extra-item hidden' : ''}`}
              >
                <div class="flex items-start justify-between gap-2 mb-2">
                  <h4 class="font-semibold text-charcoal text-sm leading-snug">{item.name}</h4>
                  <span class="flex-shrink-0 bg-primary/10 text-primary text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap">
                    {item.distance}
                  </span>
                </div>
                <p class="text-stone-500 text-xs leading-relaxed">{item.tip}</p>
                {item.mapsUrl && (
                  <a
                    href={item.mapsUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 mt-2 text-primary text-xs font-semibold hover:underline"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Open in Maps
                  </a>
                )}
              </div>
            ))}
          </div>
          {group.items.length > VISIBLE_COUNT && (
            <button
              type="button"
              data-toggle-group={gi}
              data-hidden-count={group.items.length - VISIBLE_COUNT}
              class="toggle-btn mt-4 w-full flex items-center justify-center gap-2 text-primary text-sm font-semibold py-3 rounded-2xl border border-primary/30 hover:bg-primary/5 transition-colors"
            >
              <span class="toggle-label">Show {group.items.length - VISIBLE_COUNT} more</span>
              <svg class="toggle-chevron h-4 w-4 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>('.toggle-btn').forEach((btn) => {
    const groupId = btn.getAttribute('data-toggle-group');
    const hiddenCount = parseInt(btn.getAttribute('data-hidden-count') ?? '0', 10);
    const grid = document.querySelector<HTMLElement>(`[data-group="${groupId}"]`);
    if (!grid) return;

    let expanded = false;

    btn.addEventListener('click', () => {
      expanded = !expanded;
      grid.querySelectorAll<HTMLElement>('.extra-item').forEach((el) => {
        el.classList.toggle('hidden', !expanded);
      });
      const label = btn.querySelector('.toggle-label');
      const chevron = btn.querySelector<HTMLElement>('.toggle-chevron');
      if (label) label.textContent = expanded ? 'Show less' : `Show ${hiddenCount} more`;
      if (chevron) chevron.style.transform = expanded ? 'rotate(180deg)' : '';
    });
  });
</script>
