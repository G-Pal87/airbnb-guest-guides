  "thingsToDo": [
    {
      "category": "Beaches 🏝️",
      "items": [
        { "name": "Venus Beach", "distance": "Short walk", "tip": "Sandy beach perfect for swimming and sunbathing. Famous for some of the most beautiful sunsets on the whole island!" },
        { "name": "Faros (Lighthouse) Beach", "distance": "15 min walk", "tip": "Calm atmosphere with sun beds and umbrellas. Crystal-clear waters — great for families and quiet days by the sea." },
        { "name": "Alykes Beach", "distance": "Near Paphos harbor", "tip": "Lively beach with easy access to cafes and restaurants along the waterfront." },
        { "name": "White River Beach", "distance": "Short drive", "tip": "A hidden gem with stunning natural beauty. Unique zen stone art installations scattered around make this place truly special." }
      ]
    },
    {
      "category": "Historical Sites & Scenic Walks 🏰",
      "items": [
        { "name": "Tombs of the Kings", "distance": "8 min walk", "tip": "UNESCO World Heritage site. Ancient tombs carved from solid rock — a unique look at Paphos's rich history." },
        { "name": "Paphos Castle & Harbor (Limani)", "distance": "30 min walk", "tip": "Historic castle right by the harbour — lovely for exploring and waterfront dining." },
        { "name": "Harbor Promenade", "distance": "30 min walk", "tip": "Follow the promenade from the Castle along the Limani for scenic views, shops and dining. Especially charming at sunset. 🌅" }
      ]
    },
    {
      "category": "Attractions & Excursions 📸",
      "items": [
        { "name": "Blue Lagoon (Akamas)", "distance": "30 min drive + boat from Latchi", "tip": "Breathtaking turquoise waters — ideal for snorkelling and swimming. Take a boat trip from Latchi harbour." },
        { "name": "Paphos Wreck (MV Demetrios II)", "distance": "15 min drive", "tip": "Shipwreck visible from shore near Chloraka. A favourite for photographers — adds a touch of maritime mystery to the coastline." },
        { "name": "Aphrodite's Rock (Petra tou Romiou)", "distance": "25 min drive", "tip": "The legendary birthplace of Aphrodite. Iconic rock formation with fantastic photo opportunities." },
        { "name": "Akamas Peninsula", "distance": "45 min drive", "tip": "Nature reserve ideal for hiking, with the Blue Lagoon accessible by foot trail or boat." },
        { "name": "Troodos Mountains", "distance": "1 hour drive", "tip": "Stunning mountain scenery, great for hiking and exploring traditional villages. A world apart from the coast." },
        { "name": "Wine Tasting", "distance": "Varies", "tip": "Nearby wineries offer tastings and tours. Try Vouni Panayia Winery for an authentic local wine experience." }
      ]
    },
    {
      "category": "Hiking & Nature Trails ⛰️",
      "items": [
        { "name": "Avakas Gorge", "distance": "Akamas Peninsula", "tip": "Scenic 2–3 hour hike through impressive rock formations and diverse flora. Best enjoyed early in the morning." },
        { "name": "Kremiotis Waterfall", "distance": "30 min drive", "tip": "Hidden waterfall near Kritou Terra — peaceful hike through lush surroundings. Especially beautiful after the rainy season." },
        { "name": "Aphrodite & Adonis Nature Trails", "distance": "Akamas Peninsula", "tip": "Interconnected trails with breathtaking coastal views and views of the Blue Lagoon below. Start near the Baths of Aphrodite. Moderately challenging." }
      ]
    }
