---
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title: string;
  propertyName: string;
  translations?: Record<string, unknown>;
  theme?: string | null;
}

const { title, propertyName, translations, theme } = Astro.props;
const i18nJson = translations ? JSON.stringify(translations) : '{}';
const isTenerife = theme === 'tenerife';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth" data-theme={isTenerife ? 'tenerife' : undefined}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0E7490" />
    <meta name="description" content={`Guest guide for ${propertyName}`} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏖️</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    {isTenerife && (
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,360;0,9..144,460;0,9..144,560;1,9..144,400&family=Karla:ital,wght@0,400;0,500;0,700;1,400&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet"
      />
    )}
    <script is:inline define:vars={{ i18nJson }}>
      window.__i18n__ = JSON.parse(i18nJson);
    </script>
    <style is:global>
/* ---- Brand color tokens (default / Cyprus) ---- */
:root{
  --c-primary:14 116 144;   /* #0E7490 teal */
  --c-accent:245 158 11;    /* #F59E0B amber */
  --c-surface:250 250 248;  /* #FAFAF8 */
  --c-charcoal:28 25 23;    /* #1C1917 */
}

/* Accordion slide-in animation */
details > div {
  animation: accordionSlide 0.2s ease-out;
}
@keyframes accordionSlide {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Open accordion: left accent border + elevated shadow */
details[open] {
  box-shadow: 0 4px 24px rgba(14,116,144,0.10), 0 1px 4px rgba(14,116,144,0.08) !important;
  border-left: 3px solid #0E7490 !important;
  border-radius: 1rem !important;
}

/* Emergency section: red accent when open */
#emergency details[open] {
  box-shadow: 0 4px 24px rgba(220,38,38,0.10) !important;
  border-left: 3px solid #DC2626 !important;
}

/* Check-in key card: amber accent when open */
#checkin details[open]:first-of-type {
  box-shadow: 0 4px 24px rgba(245,158,11,0.12) !important;
  border-left: 3px solid #F59E0B !important;
}

/* Section heading decorative underline */
[id$="-heading"] {
  position: relative;
  padding-bottom: 0.75rem;
  margin-bottom: 1.75rem !important;
}
[id$="-heading"]::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 2.5rem;
  height: 3px;
  background: linear-gradient(to right, #0E7490, #06B6D4);
  border-radius: 9999px;
}
/* Emergency heading keeps red underline */
#emergency [id$="-heading"]::after {
  background: linear-gradient(to right, #DC2626, #F87171);
}

/* Expanded content body text slightly larger */
details[open] p {
  font-size: 0.9rem;
  line-height: 1.65;
}

/* ===========================================================
   TENERIFE THEME — warm Canarian palette (formatting only)
   Same skeleton, same functionality. Cyprus is unaffected.
   =========================================================== */
html[data-theme="tenerife"]{
  --c-primary:30 127 140;   /* tile  #1E7F8C */
  --c-accent:232 154 47;    /* mango #E89A2F */
  --c-surface:251 243 232;  /* plaster #FBF3E8 */
  --c-charcoal:39 52 58;    /* ink   #27343A */
}

/* --- Typography --- */
html[data-theme="tenerife"] body,
html[data-theme="tenerife"] .font-sans{font-family:'Karla',system-ui,sans-serif;font-size:17px;line-height:1.65}
html[data-theme="tenerife"] .font-serif{font-family:'Fraunces',Georgia,serif}
html[data-theme="tenerife"] .font-mono{font-family:'DM Mono',monospace}

/* --- Navigation: warm plaster bg + always-visible pill links --- */
html[data-theme="tenerife"] nav#main-nav{
  background:rgba(251,243,232,.94) !important;
  border-bottom-color:rgba(30,127,140,.15) !important;
  box-shadow:0 1px 4px rgba(13,59,67,.06) !important;
}
html[data-theme="tenerife"] .nav-link{
  border:1px solid rgba(30,127,140,.40) !important;
  border-radius:9999px !important;
  color:#1E7F8C !important;
  background-color:transparent !important;
  transition:background-color .15s,color .15s,border-color .15s;
}
html[data-theme="tenerife"] .nav-link:hover,
html[data-theme="tenerife"] .nav-link:active{
  background-color:#1E7F8C !important;
  color:#fff !important;
  border-color:#1E7F8C !important;
}

/* --- QuickRef "At a Glance": light cards on plaster (mockup parity) --- */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"]{
  background:#FBF3E8 !important;       /* plaster, no dark banner */
}
/* hide the decorative blur blobs */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] > .absolute.inset-0{
  display:none !important;
}
/* heading -> atlantic ink */
html[data-theme="tenerife"] #quickref-heading{
  color:#0D3B43 !important;
}
/* glass cards -> warm light cards */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] .bg-white\/20{
  background-color:#FFFDF9 !important;
  border-color:rgba(13,59,67,.12) !important;
  color:#27343A !important;
  box-shadow:0 1px 2px rgba(13,59,67,.05),0 10px 30px -18px rgba(13,59,67,.25) !important;
}
/* labels / hints -> ink-soft */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] .text-white\/80,
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] .text-white\/70{
  color:#5C6B70 !important;
}
/* big time values -> atlantic, Fraunces */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] .text-accent{
  color:#0D3B43 !important;
}
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] p.text-2xl{
  font-family:'Fraunces',Georgia,serif !important;
  font-weight:560 !important;
  font-size:2.1rem !important;
  line-height:1.1 !important;
}
/* network name -> atlantic bold */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] .bg-white\/20 .font-medium{
  color:#0D3B43 !important;
}
/* WiFi password code -> hibiscus (coral) */
html[data-theme="tenerife"] #wifi-password-quickref{
  color:#D95F3B !important;
}
/* "Copied!" feedback -> leaf green */
html[data-theme="tenerife"] #copy-feedback-quickref{
  color:#5F7D52 !important;
}
/* icon copy button -> plaster-deep pill */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] button.bg-white\/20{
  background-color:#F4E7D4 !important;
  border:1px solid rgba(13,59,67,.12) !important;
  color:#0D3B43 !important;
}
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] button.bg-white\/20:hover{
  background-color:#EAD9BF !important;
}
/* Contact CTA button -> solid tile with light text */
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] a.bg-accent{
  background-color:#1E7F8C !important;
  color:#FDF8EE !important;
  box-shadow:0 8px 20px -10px rgba(30,127,140,.6) !important;
}
html[data-theme="tenerife"] section[aria-labelledby="quickref-heading"] a.bg-accent:hover{
  background-color:#14525C !important;
}

/* --- Cards: warm white + warm borders + warm shadows --- */
html[data-theme="tenerife"] .bg-white{background-color:#FFFDF9}
html[data-theme="tenerife"] .border-stone-100{border-color:rgba(13,59,67,.10)}
html[data-theme="tenerife"] .border-stone-200{border-color:rgba(13,59,67,.16)}
html[data-theme="tenerife"] .shadow-sm{box-shadow:0 1px 3px rgba(13,59,67,.07) !important}
html[data-theme="tenerife"] .shadow-md{box-shadow:0 1px 3px rgba(13,59,67,.06),0 8px 24px -10px rgba(13,59,67,.20) !important}
html[data-theme="tenerife"] .shadow-lg{box-shadow:0 4px 8px rgba(13,59,67,.07),0 16px 40px -14px rgba(13,59,67,.26) !important}

/* --- Text neutrals --- */
html[data-theme="tenerife"] .text-stone-600{color:#5C6B70}
html[data-theme="tenerife"] .text-stone-500{color:#617078}
html[data-theme="tenerife"] .text-stone-400{color:#8A9499}
html[data-theme="tenerife"] .bg-stone-100{background-color:#F4E7D4}
html[data-theme="tenerife"] .bg-stone-200{background-color:#EAD9BF}
html[data-theme="tenerife"] .hover\:bg-stone-200:hover{background-color:#EAD9BF}
html[data-theme="tenerife"] .ring-stone-400{--tw-ring-color:#1E7F8C}

/* --- Amber/mango accents --- */
html[data-theme="tenerife"] .bg-amber-50{background-color:#FCF1DC}
html[data-theme="tenerife"] .bg-amber-100{background-color:#F8E4C0}
html[data-theme="tenerife"] .hover\:bg-amber-100:hover{background-color:#F3D9A8}
html[data-theme="tenerife"] .border-amber-200{border-color:rgba(232,154,47,.45)}
html[data-theme="tenerife"] .text-amber-700{color:#9A6320}
html[data-theme="tenerife"] .text-amber-800{color:#7d4d12}

/* --- Info notes (blue -> warm teal) --- */
html[data-theme="tenerife"] .bg-blue-50{background-color:#EAF3F4}
html[data-theme="tenerife"] .border-blue-200{border-color:rgba(30,127,140,.25)}
html[data-theme="tenerife"] .text-blue-700,
html[data-theme="tenerife"] .text-blue-800,
html[data-theme="tenerife"] .text-blue-900{color:#19545E}

/* --- Button hover overrides --- */
html[data-theme="tenerife"] .hover\:bg-teal-700:hover{background-color:#14525C}
html[data-theme="tenerife"] .hover\:bg-yellow-300:hover{background-color:#F8D06A}

/* --- Hardcoded-gradient overrides (inline style attributes) --- */
/* Map button -> solid tile pill (mockup .btn) */
html[data-theme="tenerife"] a[style*="0E7490"]{
  background:#1E7F8C !important;
  border-radius:999px !important;
  box-shadow:0 8px 20px -10px rgba(30,127,140,.6) !important;
  transition:background .15s,transform .15s !important;
}
html[data-theme="tenerife"] a[style*="0E7490"]:hover{
  background:#14525C !important;
  transform:translateY(-1px);
}
/* Welcome card left accent bar */
html[data-theme="tenerife"] .w-1[style*="0E7490"]{
  background:linear-gradient(to bottom,#1E7F8C,#E89A2F) !important;
}

/* --- Plaster page, white cards (mockup model) --- */
/* every white section -> plaster background (matches body/page) */
html[data-theme="tenerife"] section.bg-white{
  background-color:#FBF3E8 !important;
}
/* card-level surfaces (not the section/body) -> warm white card */
html[data-theme="tenerife"] .bg-surface:not(section):not(body){
  background-color:#FFFDF9 !important;
}
/* welcome band wrapper -> plaster, to match the rest of the page */
html[data-theme="tenerife"] section[aria-label="Hero"] > .bg-white{
  background-color:#FBF3E8 !important;
}
/* street / address line -> Fraunces atlantic (mockup .street) */
html[data-theme="tenerife"] #getting-here .leading-snug{
  font-family:'Fraunces',Georgia,serif !important;
  color:#0D3B43 !important;
  font-size:1.35rem !important;
  font-weight:560 !important;
  line-height:1.3 !important;
}
/* accordion summary titles -> atlantic bold (mockup fold summary) */
html[data-theme="tenerife"] details > summary .text-charcoal{
  color:#0D3B43 !important;
}

/* --- Accordion cards: warm card bg --- */
html[data-theme="tenerife"] details:not(.bg-primary){background-color:#FFFDF9}

/* WiFi accordion: warm white card with dark text for contrast */
html[data-theme="tenerife"] #wifi details.bg-primary{
  background-color:#FFFDF9 !important;
  border:1px solid rgba(13,59,67,.10) !important;
  color:#27343A !important;
}
html[data-theme="tenerife"] #wifi details.bg-primary summary span.font-semibold{color:#0D3B43 !important}
html[data-theme="tenerife"] #wifi details.bg-primary summary svg{color:#8A9499 !important}
html[data-theme="tenerife"] #wifi details.bg-primary .border-white\/20{border-color:rgba(13,59,67,.10) !important}
html[data-theme="tenerife"] #wifi details.bg-primary .bg-white\/15{background-color:#F4E7D4 !important}
html[data-theme="tenerife"] #wifi details.bg-primary .text-white\/70{color:#617078 !important}
html[data-theme="tenerife"] #wifi details.bg-primary .font-medium.text-white{color:#0D3B43 !important}
html[data-theme="tenerife"] #wifi details.bg-primary .bg-white\/20{background-color:rgba(13,59,67,.08) !important;color:#617078 !important}
html[data-theme="tenerife"] #wifi details.bg-primary button.bg-white\/20{background-color:#EAD9BF !important;color:#0D3B43 !important}
html[data-theme="tenerife"] #wifi details.bg-primary button.bg-white\/20:hover{background-color:#DEC9A8 !important}
html[data-theme="tenerife"] #wifi details.bg-primary .text-white\/80{color:#617078 !important}

/* Open accordion: tile accent */
html[data-theme="tenerife"] details[open]{
  box-shadow:0 4px 24px rgba(30,127,140,.10),0 1px 4px rgba(30,127,140,.08) !important;
  border-left:3px solid #1E7F8C !important;
  border-radius:1rem !important;
}
/* Emergency: red stays red */
html[data-theme="tenerife"] #emergency details[open]{
  box-shadow:0 4px 24px rgba(220,38,38,.10) !important;
  border-left:3px solid #DC2626 !important;
}
/* Check-in key card: mango when open */
html[data-theme="tenerife"] #checkin details[open]:first-of-type{
  box-shadow:0 4px 24px rgba(232,154,47,.12) !important;
  border-left:3px solid #E89A2F !important;
}
/* WiFi accordion (bg-primary) open: mango left bar */
html[data-theme="tenerife"] #wifi details.bg-primary[open]{
  border-left:3px solid #E89A2F !important;
}

/* --- Section headings -> Fraunces + tile-dots decorator (mockup) --- */
html[data-theme="tenerife"] [id$="-heading"]{
  color:#0D3B43 !important;        /* atlantic */
  font-weight:460 !important;
  padding-bottom:0 !important;
  display:inline-flex;
  align-items:center;             /* dots ride on the same row as the text */
}
/* three colour diamonds (tile / mango / hibiscus) in a straight row */
html[data-theme="tenerife"] [id$="-heading"]::after{
  content:"";
  position:relative;
  top:1px;
  width:34px;
  height:10px;
  margin-left:18px;
  transform:none;
  box-shadow:none;
  border-radius:0;
  background:no-repeat center/contain url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='34' height='10' viewBox='0 0 34 10'><polygon points='4,1 8,5 4,9 0,5' fill='%231E7F8C'/><polygon points='17,1 21,5 17,9 13,5' fill='%23E89A2F'/><polygon points='30,1 34,5 30,9 26,5' fill='%23D95F3B'/></svg>");
}
/* Emergency heading keeps its red identity (no tile-dots) */
html[data-theme="tenerife"] #emergency [id$="-heading"]{
  color:#B91C1C !important;
}
html[data-theme="tenerife"] #emergency [id$="-heading"]::after{
  display:none;
}

/* --- Emergency "nearest services": warm leaf-green pharmacy card --- */
html[data-theme="tenerife"] .bg-green-50{background-color:#EDF1E8}
html[data-theme="tenerife"] .border-green-200{border-color:rgba(95,125,82,.30)}
html[data-theme="tenerife"] .text-green-700,
html[data-theme="tenerife"] .text-green-900{color:#46603C}
/* WhatsApp / leaf action buttons keep a warm leaf tone */
html[data-theme="tenerife"] .bg-green-500{background-color:#5F7D52}
html[data-theme="tenerife"] .hover\:bg-green-600:hover{background-color:#4d6843}
/* Things-to-do price chips */
html[data-theme="tenerife"] .bg-green-100{background-color:#E2EAD9}
html[data-theme="tenerife"] .bg-orange-100{background-color:#F6E0CC}
html[data-theme="tenerife"] .text-orange-700{color:#9A5A20}

/* --- Things-to-do: tile count badge + item chips --- */
html[data-theme="tenerife"] .bg-primary\/10{background-color:rgba(30,127,140,.12)}

/* --- Expanded accordion text uses warm ink --- */
html[data-theme="tenerife"] details[open] p{
  color:#3A4A50;
  font-size:0.9rem;
  line-height:1.7;
}
    </style>
  </head>
  <body class="bg-surface font-sans text-charcoal antialiased">
    <LanguageSwitcher />
    <slot />
    <script is:inline>
    (function() {
      function getNestedValue(obj, path) {
        return path.split('.').reduce(function(cur, key) {
          if (cur === null || cur === undefined) return undefined;
          return cur[isNaN(key) ? key : Number(key)];
        }, obj);
      }

      function applyLanguage(lang) {
        var translations = window.__i18n__;
        if (!translations) return;

        if (lang === 'en' || !translations[lang]) {
          updateButtons(lang);
          return;
        }

        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          var value = getNestedValue(translations[lang], key);
          if (value !== undefined && value !== null) {
            if (el.hasAttribute('data-i18n-html')) {
              el.innerHTML = value;
            } else {
              el.textContent = value;
            }
          }
        });

        updateButtons(lang);
      }

      function updateButtons(lang) {
        document.querySelectorAll('[data-lang-btn]').forEach(function(btn) {
          var isActive = btn.getAttribute('data-lang-btn') === lang;
          if (isActive) {
            btn.classList.add('bg-primary', 'text-white');
            btn.classList.remove('bg-white', 'text-stone-600');
          } else {
            btn.classList.remove('bg-primary', 'text-white');
            btn.classList.add('bg-white', 'text-stone-600');
          }
        });
      }

      document.addEventListener('DOMContentLoaded', function() {
        var savedLang = localStorage.getItem('lang') || 'en';
        if (savedLang !== 'en') {
          applyLanguage(savedLang);
        }
        updateButtons(savedLang);

        document.querySelectorAll('[data-lang-btn]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var lang = btn.getAttribute('data-lang-btn');
            if (lang === 'en') {
              localStorage.removeItem('lang');
              location.reload();
            } else {
              localStorage.setItem('lang', lang);
              applyLanguage(lang);
            }
          });
        });
      });
    })();
    </script>
  </body>
</html>
